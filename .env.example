# ---------------------------------------------------------------------------
# Job Matcher — environment variables
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------------------------

# === Local dev (defaults — no changes needed for local use) ================

# Local DuckDB file path (used when DATABASE_URL is not set)
DB_PATH=data/mcf.duckdb

# Path to a local resume file for the single-user local flow
RESUME_PATH=resume/resume.pdf

# Default user ID for local dev (no auth)
DEFAULT_USER_ID=default_user

# Allow requests without Authorization header (local dev only; never use in production)
# ALLOW_ANONYMOUS_LOCAL=true

# API port
API_PORT=8000

# === Hosted deployment (Supabase + Railway) =================================

# PostgreSQL connection string from Supabase > Settings > Database > Connection string
# Uncomment and fill in to switch the backend to Postgres:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase project URL (from Supabase > Settings > API)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Supabase anon/public key (frontend — safe to expose)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role key (backend only — keep secret!)
# SUPABASE_SERVICE_KEY=eyJ...

# Legacy JWT secret (only if project has not migrated to JWT Signing Keys)
# New projects use JWKS automatically via SUPABASE_URL; omit this.
# SUPABASE_JWT_SECRET=your-super-secret-jwt-token

# Comma-separated list of allowed CORS origins (e.g. your Vercel domain)
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# === Admin & cache invalidation ============================================

# Secret for crawl webhook and admin endpoints (crawl, revalidate)
# CRON_SECRET=your-secret

# User IDs allowed to access /admin (comma-separated Supabase auth UUIDs)
# ADMIN_USER_IDS=uuid1,uuid2

# Next.js app URL for crawl webhook (set in crawl env; e.g. Vercel URL)
# CRAWL_WEBHOOK_URL=https://your-app.vercel.app

# === Careers@Gov (CAG) Algolia credentials ================================
# Public read-only key scraped from https://jobs.careers.gov.sg/
# If CAG crawl returns 0 jobs (HTTP 403/429), the key may have rotated.
# Update via DevTools Network tab on that site.
# CAG_ALGOLIA_APP_ID=3OW7D8B4IZ
# CAG_ALGOLIA_API_KEY=32fa71d8b0bc06be1e6395bf8c430107
